# ─── CrowdSense Firebase Config ───
# 1. Go to https://console.firebase.google.com
# 2. Create a new project (or use existing)
# 3. Add a Web app → copy the config values below
# 4. Enable Authentication → Sign-in methods → Google + Email/Password
# 5. Create Firestore Database (start in test mode)
# 6. Copy this file to .env and fill in your values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Set to "true" to use Firebase backend. Set to "false" to use mock data (demo mode).
VITE_USE_FIREBASE=false
